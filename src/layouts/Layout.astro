---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Elevify - Elevate your everyday experience with our premium app." } = Astro.props;

const base = import.meta.env.BASE_URL;
const resolvePath = (path) => {
	if (base === '/') return path;
	const p = path.startsWith('/') ? path.slice(1) : path;
	return (base.endsWith('/') ? base : base + '/') + p;
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href={resolvePath("/icon.png")} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-[#050505] text-gray-100 selection:bg-purple-500/30 overflow-x-hidden antialiased">
		<!-- Dynamic Background Globs -->
		<div class="fixed top-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-purple-600/10 blur-[120px] pointer-events-none z-[-1]"></div>
		<div class="fixed bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-indigo-600/10 blur-[120px] pointer-events-none z-[-1]"></div>
		
		<header class="fixed top-0 w-full z-50 bg-[#050505]/60 backdrop-blur-xl border-b border-white/10 py-4">
			<div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
				<a href={resolvePath("/")} class="text-2xl font-bold text-white tracking-tighter flex items-center gap-3">
					<img src={resolvePath("/icon.png")} alt="Elevify Icon" class="w-9 h-9 rounded-xl shadow-lg shadow-purple-500/20 object-cover" />
					Elevify
				</a>
				<nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-300">
					<a href={resolvePath("/")} class="hover:text-white transition-colors">Home</a>
					<a href={resolvePath("/features")} class="hover:text-white transition-colors">Features</a>
					<a href={resolvePath("/privacy-policy")} class="hover:text-white transition-colors">Privacy</a>
				</nav>
				<a href="#download" class="hidden md:inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white bg-white/10 hover:bg-white/20 border border-white/10 rounded-full transition-all duration-300 backdrop-blur-md">
					Get the App
				</a>
			</div>
		</header>

		<main class="pt-24 min-h-screen">
			<slot />
		</main>

		<footer class="mt-24 border-t border-white/10 bg-black/20 backdrop-blur-xl">
			<div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
				<div class="flex items-center gap-3">
					<img src={resolvePath("/icon.png")} alt="Elevify Icon" class="w-7 h-7 rounded border border-white/10 object-cover" />
					<span class="text-xl font-bold tracking-tighter text-white">Elevify</span>
				</div>
				<div class="text-sm text-gray-400">
					&copy; {new Date().getFullYear()} RGsoft. All rights reserved.
				</div>
				<div class="flex gap-6 text-sm font-medium text-gray-400">
					<a href={resolvePath("/privacy-policy")} class="hover:text-white transition-colors">Privacy Policy</a>
					<a href={resolvePath("/support")} class="hover:text-white transition-colors">Support</a>
				</div>
			</div>
		</footer>
	</body>
</html>
