---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Support - Elevify App" description="Get help and support for Elevify">
	<section class="py-32 relative z-10 min-h-screen flex items-center">
		<div class="max-w-3xl mx-auto px-6 w-full">
			<div class="text-center mb-12">
				<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border-white/10 text-sm font-medium text-purple-300 mb-6">
					We're here to help
				</div>
				<h1 class="text-4xl lg:text-5xl font-bold text-white text-glow mb-6">Support & Contact</h1>
				<p class="text-gray-400 text-lg">Having trouble with Elevify? Reach out to our support team and we'll get back to you as soon as possible.</p>
			</div>
			
			<div class="glass-card rounded-3xl p-8 lg:p-12">
				<form class="space-y-6" onsubmit="event.preventDefault(); alert('This is a static demo. In production, this form would send an email directly to support!');">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						<div class="space-y-2">
							<label for="name" class="block text-sm font-medium text-gray-300">Name</label>
							<input type="text" id="name" placeholder="John Doe" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500 transition-all" required />
						</div>
						<div class="space-y-2">
							<label for="email" class="block text-sm font-medium text-gray-300">Email Address</label>
							<input type="email" id="email" placeholder="john@example.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500 transition-all" required />
						</div>
					</div>
					
					<div class="space-y-2">
						<label for="subject" class="block text-sm font-medium text-gray-300">Subject</label>
						<select id="subject" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500 transition-all appearance-none">
							<option value="bug" class="bg-gray-900">Report a Bug</option>
							<option value="feature" class="bg-gray-900">Feature Request</option>
							<option value="account" class="bg-gray-900">Account Issue</option>
							<option value="other" class="bg-gray-900">Other</option>
						</select>
					</div>

					<div class="space-y-2">
						<label for="message" class="block text-sm font-medium text-gray-300">Message</label>
						<textarea id="message" rows="5" placeholder="How can we help you today?" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500/50 focus:border-purple-500 transition-all resize-y" required></textarea>
					</div>

					<button type="submit" class="w-full inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 rounded-xl shadow-lg shadow-purple-500/20 transition-all duration-300">
						Send Message
					</button>
				</form>
				
				<div class="mt-8 pt-8 border-t border-white/10 text-center">
					<p class="text-gray-400 text-sm">Or email us directly at <a href="mailto:robert.gjoshevski@outlook.com" class="font-medium text-purple-400 hover:text-purple-300 transition-colors">robert.gjoshevski@outlook.com</a></p>
				</div>
			</div>
		</div>
	</section>
</Layout>
