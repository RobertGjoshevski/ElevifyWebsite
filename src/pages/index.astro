---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Elevify - The Ultimate Mobile Experience">
	<!-- Hero Section -->
	<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
		<div class="max-w-6xl mx-auto px-6 relative z-10">
			<div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
				<div class="max-w-2xl">
					<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border-white/10 text-sm font-medium text-purple-300 mb-6">
						<span class="relative flex h-2 w-2">
							<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-purple-400 opacity-75"></span>
							<span class="relative inline-flex rounded-full h-2 w-2 bg-purple-500"></span>
						</span>
						v2.0 is now live
					</div>
					<h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white mb-6 leading-[1.1]">
						Elevate your <br/>
						<span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400 text-glow">everyday routine.</span>
					</h1>
					<p class="text-lg text-gray-400 mb-10 max-w-xl leading-relaxed">
						Experience the pinnacle of personal growth and productivity. Elevify brings beautiful design and powerful tools straight to your pocket, helping you achieve more with less effort.
					</p>
					
					<div class="flex flex-col sm:flex-row gap-4" id="download">
						<a href="#" class="flex items-center justify-center gap-3 px-8 py-4 rounded-2xl bg-white text-black font-semibold hover:scale-105 hover:shadow-xl hover:shadow-white/20 transition-all duration-300">
							<svg class="w-6 h-6" viewBox="0 0 384 512" fill="currentColor">
								<path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z"/>
							</svg>
							<div class="flex flex-col items-start translate-y-[-2px]">
								<span class="text-[10px] font-medium leading-none mb-1 opacity-80">Download on the</span>
								<span class="text-base leading-none">App Store</span>
							</div>
						</a>
						<a href="#" class="flex items-center justify-center gap-3 px-8 py-4 rounded-2xl glass-card text-white font-semibold hover:scale-105 transition-all duration-300">
							<svg class="w-6 h-6 text-green-400" viewBox="0 0 512 512" fill="currentColor">
								<path d="M325.3 234.3L104.6 13l280.8 161.2-60.1 60.1zM47 0C34 6.8 25.3 19.2 25.3 35.3v441.3c0 16.1 8.7 28.5 21.7 35.3l256-256L47 0zm425.2 225.6l-58.9-34.1-65.7 64.5 65.7 64.5 60.1-34.1c18-14.3 18-46.5-1.2-60.8zM104.6 499l280.8-161.2-60.1-60.1L104.6 499z"/>
							</svg>
							<div class="flex flex-col items-start translate-y-[-2px]">
								<span class="text-[10px] font-medium leading-none mb-1 opacity-80">GET IT ON</span>
								<span class="text-base leading-none">Google Play</span>
							</div>
						</a>
					</div>
				</div>
				
				<!-- Mockup Illustration (CSS Only for premium feel) -->
				<div class="relative lg:h-[600px] flex justify-center lg:justify-end items-center perspective-1000">
					<div class="relative w-[280px] h-[580px] rounded-[3rem] border-[8px] border-white/10 bg-black shadow-2xl shadow-purple-500/20 glass overflow-hidden transform rotate-y-[-15deg] rotate-x-[5deg] hover:rotate-y-0 hover:rotate-x-0 transition-transform duration-700 ease-out">
						<!-- Dynamic Screen content -->
						<div class="absolute inset-0 bg-gradient-to-br from-indigo-950 via-purple-950 to-black p-6 flex flex-col gap-4">
							<div class="flex justify-between items-center mb-4">
								<div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
									<div class="w-8 h-8 rounded-full border-2 border-purple-500"></div>
								</div>
								<div class="w-8 h-8 rounded-full bg-white/5"></div>
							</div>
							
							<div class="w-3/4 h-8 rounded-lg bg-white/10 mb-2"></div>
							<div class="w-1/2 h-4 rounded-lg bg-white/5 mb-8"></div>
							
							<!-- Dashboard Cards Mockup -->
							<div class="grid grid-cols-2 gap-3 h-32">
								<div class="rounded-2xl bg-gradient-to-br from-purple-500/20 to-indigo-500/20 border border-white/10 p-4 flex flex-col justify-end">
									<div class="w-8 h-8 rounded bg-white/20 mb-auto"></div>
									<div class="w-full h-3 rounded bg-white/20 mt-2"></div>
								</div>
								<div class="rounded-2xl bg-white/5 border border-white/5 p-4 flex flex-col justify-end">
									<div class="w-8 h-8 rounded bg-white/10 mb-auto"></div>
									<div class="w-3/4 h-3 rounded bg-white/10 mt-2"></div>
								</div>
							</div>
							
							<div class="flex-1 rounded-2xl bg-white/5 border border-white/5 mt-4 p-4">
								<div class="w-full h-2 rounded bg-white/10 mb-3"></div>
								<div class="w-5/6 h-2 rounded bg-white/10 mb-3"></div>
								<div class="w-4/6 h-2 rounded bg-white/10"></div>
							</div>
						</div>
						<!-- Notch -->
						<div class="absolute top-0 inset-x-0 h-6 flex justify-center">
							<div class="w-32 h-6 bg-black rounded-b-xl border-x-[8px] border-b-[8px] border-transparent"></div>
						</div>
					</div>
					
					<!-- Decorative glowing orbs around mockup -->
					<div class="absolute top-1/4 -left-12 w-24 h-24 bg-purple-500 rounded-full mix-blend-screen filter blur-xl opacity-50 animate-pulse"></div>
					<div class="absolute bottom-1/4 -right-12 w-32 h-32 bg-indigo-500 rounded-full mix-blend-screen filter blur-xl opacity-40"></div>
				</div>
			</div>
		</div>
	</section>

	<!-- Features / Bento Grid -->
	<section id="features" class="py-24 relative z-10 border-t border-white/5 bg-black/40">
		<div class="max-w-6xl mx-auto px-6">
			<div class="mb-16 text-center">
				<h2 class="text-3xl lg:text-5xl font-bold mb-6">Designed to <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400">empower you</span>.</h2>
				<p class="text-gray-400 max-w-2xl mx-auto text-lg">Everything you need, packed into an intuitive and stunning interface. Elevify adapts to your workflow seamlessly.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[250px]">
				<!-- Large Card -->
				<div class="md:col-span-2 md:row-span-2 glass-card rounded-3xl p-8 flex flex-col relative overflow-hidden group">
					<div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
					<div class="relative z-10 w-14 h-14 rounded-2xl bg-purple-500/20 border border-purple-500/30 flex items-center justify-center mb-6">
						<svg class="w-7 h-7 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
						</svg>
					</div>
					<h3 class="text-2xl font-bold text-white mb-3">Lightning Fast Performance</h3>
					<p class="text-gray-400 mb-8 max-w-md">Built for speed, Elevify ensures that your experience is fluid and uncompromising, no matter what device you use.</p>
					
					<div class="mt-auto h-32 rounded-xl bg-gradient-to-r from-white/5 to-white/0 border border-white/5 p-4 flex items-end">
						<div class="w-full flex gap-2 items-end h-full">
							{[40, 70, 45, 90, 65, 100, 80].map((h) => 
								<div class="flex-1 bg-gradient-to-t from-purple-500/50 to-purple-400 rounded-t-sm opacity-80" style={`height: ${h}%`}></div>
							)}
						</div>
					</div>
				</div>

				<!-- Small Card 1 -->
				<div class="glass-card rounded-3xl p-8 flex flex-col group">
					<div class="w-12 h-12 rounded-2xl bg-blue-500/20 border border-blue-500/30 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-2">Unbreakable Security</h3>
					<p class="text-gray-400 text-sm">Your data is encrypted end-to-end, keeping your life private and secure.</p>
				</div>

				<!-- Small Card 2 -->
				<div class="glass-card rounded-3xl p-8 flex flex-col group">
					<div class="w-12 h-12 rounded-2xl bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
						</svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-2">Sync Everywhere</h3>
					<p class="text-gray-400 text-sm">Start on your phone, finish on your tablet. Instant syncing across all your devices.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Call to Action -->
	<section class="py-24 relative z-10 overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-b from-transparent to-purple-900/20 pointer-events-none"></div>
		<div class="max-w-4xl mx-auto px-6 text-center relative">
			<div class="inline-flex justify-center items-center w-20 h-20 rounded-3xl bg-gradient-to-br from-purple-500 to-indigo-600 mb-8 shadow-2xl shadow-purple-500/40">
				<svg class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
				</svg>
			</div>
			<h2 class="text-4xl lg:text-5xl font-bold mb-6 text-white text-glow">Ready to Elevate?</h2>
			<p class="text-gray-400 text-lg mb-10 max-w-xl mx-auto">Join thousands of users who have transformed their daily routines. Download Elevify today and start your journey.</p>
			
			<a href="#download" class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 rounded-full shadow-lg shadow-purple-500/30 hover:shadow-purple-500/50 hover:-translate-y-1 transition-all duration-300">
				Download Elevify Now
			</a>
		</div>
	</section>
</Layout>

<style>
	.perspective-1000 {
		perspective: 1000px;
	}
</style>
