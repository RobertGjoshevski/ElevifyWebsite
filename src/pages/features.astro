---
import Layout from '../layouts/Layout.astro';

const features = [
  {
    title: "AI Agent",
    description: "Your personalized AI assistant that has deep context of your data. It can create new entries, provide actionable advice, and proactively help manage your day.",
    icon: `<svg class="w-7 h-7 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    color: "bg-purple-500/20 border-purple-500/30"
  },
  {
    title: "Tasks & Habits",
    description: "Create tasks, set reminders, and sync seamlessly with Google Calendar. Turn tasks into recurring habits and schedule them precisely to match your routine.",
    icon: `<svg class="w-7 h-7 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
    color: "bg-indigo-500/20 border-indigo-500/30"
  },
  {
    title: "Dream Interpretation",
    description: "Log your dreams while they are fresh in your memory. Our AI will analyze the symbols and themes to explain their hidden meaning and offer insights into your subconscious.",
    icon: `<svg class="w-7 h-7 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>`,
    color: "bg-pink-500/20 border-pink-500/30"
  },
  {
    title: "Therapy & Self-Growth",
    description: "Define an AI-guided therapy protocol to improve skills, break bad habits, or build healthy ones. Follow specific routines tailored for certain days and times.",
    icon: `<svg class="w-7 h-7 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    color: "bg-blue-500/20 border-blue-500/30"
  },
  {
    title: "Smart Planner",
    description: "Design step-by-step plans manually or let the AI Agent do it for you. Perfect for planning complex trips, organizing grocery shopping, or managing personal spending.",
    icon: `<svg class="w-7 h-7 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    color: "bg-emerald-500/20 border-emerald-500/30"
  },
  {
    title: "Mood Tracking",
    description: "Daily mood logging with analytical insights. Add descriptive notes to your entries to help the AI detect patterns, triggers, and track overall emotional well-being.",
    icon: `<svg class="w-7 h-7 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    color: "bg-orange-500/20 border-orange-500/30"
  },
  {
    title: "Health Integration",
    description: "Connect natively with your phone's health app and wearables. Analyze steps, heart rate (BPM), and other vital signs natively supported by your device.",
    icon: `<svg class="w-7 h-7 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
    color: "bg-red-500/20 border-red-500/30"
  },
  {
    title: "Turkish Coffee Reader",
    description: "Take a photo of your coffee cup dregs. Our vision AI will analyze the unique patterns to provide personalized predictions and fortune readings.",
    icon: `<svg class="w-7 h-7 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
    color: "bg-amber-500/20 border-amber-500/30"
  },
  {
    title: "Daily Horoscope",
    description: "Receive insightful and accurate horoscope readings. Let the stars guide your decisions according to your specific astrological sign.",
    icon: `<svg class="w-7 h-7 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>`,
    color: "bg-yellow-500/20 border-yellow-500/30"
  },
  {
    title: "Palm Reader",
    description: "Capture a clear picture of your palm and let our AI trace your life, heart, and path lines to unveil deep insights into your destiny and traits.",
    icon: `<svg class="w-7 h-7 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11" /></svg>`,
    color: "bg-teal-500/20 border-teal-500/30"
  },
  {
    title: "Tarot Reading",
    description: "Draw virtual tarot cards for clarity on your current life situations. Our AI thoroughly explains the meaning of each card and their relationship.",
    icon: `<svg class="w-7 h-7 text-fuchsia-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
    color: "bg-fuchsia-500/20 border-fuchsia-500/30"
  },
  {
    title: "Facial Etching",
    description: "Upload your profile picture for an advanced statistical analysis of facial markers, tracking and predicting long-term muscle movements over time.",
    icon: `<svg class="w-7 h-7 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    color: "bg-cyan-500/20 border-cyan-500/30"
  }
];
---

<Layout title="Features - Elevify App" description="Explore all the powerful features of Elevify">
  <section class="py-32 relative z-10 min-h-screen">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full glass border-white/10 text-sm font-medium text-purple-300 mb-6">
          Everything you need
        </div>
        <h1 class="text-4xl lg:text-6xl font-bold text-white text-glow mb-6">Powerful <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400">Features</span></h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">Elevify combines intelligent AI capability with robust tools for productivity, health, and personal growth all in one seamless app.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(feature => (
          <div class="glass-card rounded-3xl p-8 flex flex-col group h-full hover:-translate-y-2 transition-transform duration-300">
            <div class={`w-14 h-14 rounded-2xl border flex items-center justify-center mb-6 transition-transform group-hover:scale-110 duration-300 ${feature.color}`} set:html={feature.icon} />
            <h3 class="text-2xl font-bold text-white mb-3 tracking-tight">{feature.title}</h3>
            <p class="text-gray-400 leading-relaxed text-sm flex-grow">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <div class="mt-24 text-center">
        <a href={import.meta.env.BASE_URL + "#download"} class="inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 rounded-full shadow-lg shadow-purple-500/30 hover:shadow-purple-500/50 hover:-translate-y-1 transition-all duration-300">
          Get Elevify Today
        </a>
      </div>
    </div>
  </section>
</Layout>
